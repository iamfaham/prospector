# Copy this file to .env and fill in your values
# .env is gitignored — never commit real keys

# Required: LLM provider (OpenRouter)
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Required: web search (Tavily — 1,000 queries/month FREE, no credit card)
# Sign up at https://app.tavily.com → copy API key
TAVILY_API_KEY=tvly-...

# Optional: BigSet CSV export path
# Export a dataset from BigSet UI, place the CSV here, set this path
# BIGSET_EXPORT_PATH=exports/bigset_funded_startups.csv

# Optional: Apollo.io people-search API for email enrichment
# Get key at https://developer.apollo.io
# APOLLO_API_KEY=...

# Windows fix: prevents Rich from using Unicode arrows that CP1252 can't render
NO_COLOR=1
